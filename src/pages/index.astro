---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Gestor de Tareas Personal">
	<main class="max-w-2xl mx-auto p-6 md:py-12">
		
		<header class="seccion-encabezado">
			<h1 class="titulo-encabezado">Task Manager</h1>
			<p class="subtitulo-encabezado">Organiza tu día de forma sencilla</p>
		</header>
		
		<section class="contenedor-formulario">
			<form class="formulario-tarea" id="formulario-tarea">
				<input 
					type="text" 
					placeholder="¿Qué necesitas hacer hoy?" 
					class="entrada-tarea"
					required 
					id="entrada-tarea"
				/>
				<button type="submit" class="boton-principal">
					Registrar
				</button>
			</form>
		</section>

		<section class="seccion-filtros">
			<button class="boton-filtro-activo">Todas</button>
			<button class="boton-filtro">Pendientes</button>
			<button class="boton-filtro">Completadas</button>
		</section>

		<section id="lista-tareas" class="contenedor-lista-tareas">
			
			<div class="estado-vacio" id="estado-vacio">
				<div class="icono-vacio">📝</div>
				<p class="titulo-vacio">No hay tareas pendientes.</p>
				<p class="subtitulo-vacio">¡Empieza añadiendo una arriba!</p>
			</div>

			<div id="contenedor-tareas" class="flex flex-col gap-3"></div>

		</section>
	</main>

	<script>
    // 1. Estado de la aplicación
    // Se usa JSON.parse para convertir el texto guardado de vuelta a un Arreglo
    let tareas = JSON.parse(localStorage.getItem('mis-tareas-v1')) || [];
    let filtroActual = 'todas';

    // 2. Selección de elementos
    const formulario = document.getElementById('formulario-tarea');
    const inputTarea = document.getElementById('entrada-tarea');
    const contenedorTareas = document.getElementById('contenedor-tareas');
    const estadoVacio = document.getElementById('estado-vacio');
    const botonesFiltro = document.querySelectorAll('.seccion-filtros button');

    // 3. Función para renderizar tareas
    function renderizarTareas() {
        // Limpiar contenedor
        contenedorTareas.innerHTML = '';

        // Filtrar tareas según el estado
        const tareasFiltradas = tareas.filter(t => {
            if (filtroActual === 'pendientes') return !t.completada;
            if (filtroActual === 'completadas') return t.completada;
            return true;
        });

        // Mostrar/Ocultar mensaje de estado vacío
        estadoVacio.style.display = tareasFiltradas.length === 0 ? 'block' : 'none';

        // Crear elementos
        tareasFiltradas.forEach(tarea => {
            const div = document.createElement('div');
            div.className = `item-tarea ${tarea.completada ? 'tarea-completada' : ''}`;
            
            div.innerHTML = `
                <span class="texto-tarea">${tarea.texto}</span>
                <div class="flex gap-2">
                    <button class="btn-check text-sm ${tarea.completada ? 'text-indigo-600 font-bold' : 'text-slate-400 hover:text-indigo-600'}">
                        ${tarea.completada ? 'Deshacer' : 'Completar'}
                    </button>
                    <button class="btn-delete text-sm text-slate-400 hover:text-red-500">Borrar</button>
                </div>
            `;

            // Evento Completar/Pendiente
            div.querySelector('.btn-check').addEventListener('click', () => {
                tarea.completada = !tarea.completada;
                renderizarTareas();
            });

            // Evento Borrar
            div.querySelector('.btn-delete').addEventListener('click', () => {
                tareas = tareas.filter(t => t.id !== tarea.id);
                renderizarTareas();
            });

            contenedorTareas.appendChild(div);
        });
    }

    // 4. Evento Agregar Tarea
    formulario.addEventListener('submit', (e) => {
        e.preventDefault();
        const texto = inputTarea.value.trim();
        
        if (texto) {
            tareas.push({
                id: Date.now(), // ID único basado en tiempo
                texto: texto,
                completada: false
            });
            inputTarea.value = '';
            renderizarTareas();
        }
    });

    // 5. Lógica de Filtros
    botonesFiltro.forEach(boton => {
        boton.addEventListener('click', () => {
            // Actualizar clases visuales de los botones
            botonesFiltro.forEach(b => {
                b.className = 'boton-filtro';
            });
            boton.className = 'boton-filtro-activo';

            // Cambiar filtro y re-renderizar
            filtroActual = boton.textContent.toLowerCase().trim();
            // Ajuste para que coincida con el texto exacto
            if (filtroActual === 'todas') filtroActual = 'todas';
            if (filtroActual === 'pendientes') filtroActual = 'pendientes';
            if (filtroActual === 'completadas') filtroActual = 'completadas';

            renderizarTareas();
        });
    });
</script>
</Layout>