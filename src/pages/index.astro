---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Gestor de Tareas Personal">
	<main class="max-w-2xl mx-auto p-6 md:py-12">
		
		<header class="mb-10 text-center">
			<h1 class="text-3xl font-bold text-indigo-600">Task Manager</h1>
			<p class="text-slate-500">Organiza tu día de forma sencilla</p>
		</header>

		<section class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 mb-8">
			<form class="flex flex-col gap-4 sm:flex-row">
				<input 
					type="text" 
					placeholder="¿Qué necesitas hacer hoy?" 
					class="flex-1 px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all"
					required
				/>
				<button 
					type="submit" 
					class="bg-indigo-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-indigo-700 transition-colors"
				>
					Registrar
				</button>
			</form>
		</section>

		<section class="flex justify-center gap-2 mb-6">
			<button class="px-4 py-1 text-sm rounded-full bg-indigo-100 text-indigo-700 font-medium">Todas</button>
			<button class="px-4 py-1 text-sm rounded-full bg-slate-200 text-slate-600 hover:bg-slate-300">Pendientes</button>
			<button class="px-4 py-1 text-sm rounded-full bg-slate-200 text-slate-600 hover:bg-slate-300">Completadas</button>
		</section>

		<section id="task-list" class="space-y-3">
			
			<div class="text-center py-12 border-2 border-dashed border-slate-200 rounded-xl bg-slate-50/50">
				<div class="text-4xl mb-2">📝</div>
				<p class="text-slate-500">No hay tareas pendientes.</p>
				<p class="text-sm text-slate-400">¡Empieza añadiendo una arriba!</p>
			</div>

		</section>

	</main>
</Layout>