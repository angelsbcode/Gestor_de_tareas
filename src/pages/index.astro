---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Gestor de Tareas Personal">
	<main class="max-w-2xl mx-auto p-6 md:py-12">
		
		<header class="seccion-encabezado">
			<h1 class="titulo-encabezado">Task Manager</h1>
			<p class="subtitulo-encabezado">Organiza tu día de forma sencilla</p>
		</header>
		
		<section class="contenedor-formulario">
			<form class="formulario-tarea" id="formulario-tarea">
				<input 
					type="text" 
					placeholder="¿Qué necesitas hacer hoy?" 
					class="entrada-tarea"
					required 
					id="entrada-tarea"
				/>
				<button type="submit" class="boton-principal">
					Registrar
				</button>
			</form>
		</section>

		<section class="seccion-filtros">
			<button class="boton-filtro-activo">Todas</button>
			<button class="boton-filtro">Pendientes</button>
			<button class="boton-filtro">Completadas</button>
		</section>

		<section id="lista-tareas" class="contenedor-lista-tareas">
			
			<div class="estado-vacio" id="estado-vacio">
				<div class="icono-vacio">📝</div>
				<p class="titulo-vacio">No hay tareas pendientes.</p>
				<p class="subtitulo-vacio">¡Empieza añadiendo una arriba!</p>
			</div>

			<div id="contenedor-tareas" class="flex flex-col gap-3"></div>

		</section>
	</main>
</Layout>